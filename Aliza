<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Aliza - Name Animation</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background: #0f172a; /* Dark sleek background */
      font-family: 'Poppins', system-ui, -apple-system, sans-serif;
      overflow: hidden;
    }

    .name-container {
      display: flex;
      gap: 8px;
    }

    .letter {
      font-size: 5rem;
      font-weight: 800;
      color: #f8fafc;
      text-transform: uppercase;
      display: inline-block;
      cursor: pointer;
      /* Staggered entry animation */
      animation: float 3s ease-in-out infinite alternate, fadeIn 0.8s ease-out forwards;
      opacity: 0;
      text-shadow: 0 0 10px rgba(168, 85, 247, 0.5),
                   0 0 20px rgba(168, 85, 247, 0.3);
      transition: transform 0.3s ease, color 0.3s ease, text-shadow 0.3s ease;
    }

    /* Staggering the animation delay for each letter */
    .letter:nth-child(1) { animation-delay: 0.1s, 0.1s; }
    .letter:nth-child(2) { animation-delay: 0.2s, 0.2s; }
    .letter:nth-child(3) { animation-delay: 0.3s, 0.3s; }
    .letter:nth-child(4) { animation-delay: 0.4s, 0.4s; }
    .letter:nth-child(5) { animation-delay: 0.5s, 0.5s; }

    /* Interactive hover effect */
    .letter:hover {
      color: #ec4899;
      transform: translateY(-15px) scale(1.15);
      text-shadow: 0 0 15px #ec4899,
                   0 0 30px #ec4899,
                   0 0 45px #ec4899;
    }

    /* Floating keyframes */
    @keyframes float {
      0% {
        transform: translateY(0px);
      }
      100% {
        transform: translateY(-12px);
      }
    }

    /* Initial fade & pop in */
    @keyframes fadeIn {
      0% {
        opacity: 0;
        transform: translateY(30px) scale(0.8);
      }
      100% {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }
  </style>
</head>
<body>

  <div class="name-container">
    <span class="letter">A</span>
    <span class="letter">l</span>
    <span class="letter">i</span>
    <span class="letter">z</span>
    <span class="letter">a</span>
  </div>

</body>
</html>
